# Pricemon environment template. Copy to /opt/pricemon/.env and fill in.
# Lines marked REQUIRED have no default and the service will refuse to start
# without them. All others show the in-code default.

# --- Django core ---
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# "1" enables Django debug mode. Leave at "0" for any internet-facing instance.
DJANGO_DEBUG=0
# Comma-separated host list. "*" allows any Host header (fine behind a trusted LB).
DJANGO_ALLOWED_HOSTS=*

# --- Database (Postgres) ---
POSTGRES_DB=pricemon
POSTGRES_USER=pricemon
# REQUIRED.
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Cache (Memcached) ---
# host:port. The /current/ endpoint and response caching both need this reachable.
MEMCACHED_LOCATION=127.0.0.1:11211

# --- Logging ---
DJANGO_LOG_LEVEL=INFO
FEEDS_LOG_LEVEL=INFO

# --- API response cache TTLs (seconds) ---
API_CACHE_TTL_PRICES=10
API_CACHE_TTL_CANDLES=20
API_CACHE_TTL_OVERVIEW=5
API_CACHE_TTL_HISTORY=30

# --- Feed daemons ---
# systemd watchdog kicks a feed if no notify within this many seconds.
FEED_WATCHDOG_TIMEOUT_SEC=60
# Cryptofeed reconnect retries. -1 = retry forever.
FEED_RECONNECT_RETRIES=-1
# Minimum gap between publishes to memcached for /current/ (seconds).
CURRENT_PUBLISH_MIN_INTERVAL_SEC=0.5
# A /current/ row is considered live if updated within this window (seconds).
CURRENT_FRESH_SEC=10

# --- Read-time outlier filtering ---
# Drop deviant exchanges from cross-exchange rollups; clip per-exchange OHLC wicks.
# Storage is never mutated; filters apply only when views aggregate rows.
OUTLIER_FILTER_ENABLED=1
# Drop an exchange row if its vwap is more than this % from the cross-exchange median.
OUTLIER_EXCHANGE_MAX_DEV_PCT=0.5
# Clip per-exchange price_min/price_max to vwap ± this %.
OUTLIER_WICK_MAX_PCT=2.0

# --- Cross-host backfill ---
# Set ONLY on a fallback host. Bearer token guarding /api/v1/internal/aggregates/.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Leave empty on hosts that should not serve backfill data (the endpoint is
# disabled while this is unset).
# BACKFILL_API_TOKEN=
#
# Set ONLY on a primary host that pulls backfill from a fallback.
# Must match the fallback's BACKFILL_API_TOKEN exactly.
# FALLBACK_BASE_URL=http://10.0.40.62
# FALLBACK_BACKFILL_TOKEN=
# FALLBACK_BACKFILL_TIMEOUT_SEC=30
